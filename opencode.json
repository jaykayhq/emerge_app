{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "stitch": {
      "type": "local",
      "command": ["node", "stitch_proxy.mjs"],
      "enabled": false
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "mcp-fetch-server"],
      "enabled": true
    },
    "dart-mcp-server": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server",
        "--force-roots-fallback"
      ],
      "enabled": true,
      "environment": {}
    }
  }
}